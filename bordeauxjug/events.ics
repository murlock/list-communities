BEGIN:VEVENT
SUMMARY:JUG Off 2020
DTSTART;TZID=Europe/Paris:20200709T190000
DTEND;TZID=Europe/Paris:20200709T210000
UID:https://www.meetup.com/bordeauxjug/events/271759227/@community-events
DESCRIPTION:🔗 https://www.meetup.com/bordeauxjug/events/271759227/\n
 📍 Alcala\, Place Alcala de Henares\, 33400\, Talence\, France\n\nLe moi
